# Copy to .env and source it (or set these in your shell) before running the
# pipeline. Every value is optional — defaults are in pipeline/common/settings.py.

# Where the gitignored data tree (raw/, staging/, processed/) lives.
# Defaults to ./data inside the checkout.
#PULASKI_DATA_ROOT=./data

# Current CAMA export URL — it rotates; fetch the fresh link from
# https://pulaskicountyassessor.net/services/raw-data-export/ (Real Property).
#PULASKI_CAMA_URL=

# Personal-property dump URLs (rotate like the CAMA link).
#PULASKI_PP_DUMP1_URL=
#PULASKI_PP_DUMP2_URL=

# Deployed pulaski-deeds Cloudflare Worker (frontend reads web/data/services.json;
# this is for scripts/tests that hit the Worker directly).
#DEEDS_API_URL=

# Phase 1 canonical database (Neon Postgres + PostGIS). Used by
# pipeline/load_db.py; the profile Worker gets it via `wrangler secret put
# DATABASE_URL` instead. NEVER commit a real value — .env is gitignored.
PULASKI_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
